# PulseCharts backend env (Section 15). Copy to .env and fill in.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Postgres in production (Section 3). Leave unset locally to use the
# SQLite fallback. Example: postgres://user:pass@localhost:5432/pulsecharts
# DATABASE_URL=

# Redis (Channels layer + relay pub/sub)
REDIS_URL=redis://127.0.0.1:6379/0

# Hyperliquid (Section 6). Testnet: wss://api.hyperliquid-testnet.xyz/ws
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Forex data (Yahoo Finance). No API key/account needed — works from any region.
# Set FOREX_ENABLED=false to turn forex off entirely (crypto is unaffected).
FOREX_ENABLED=true
# Seconds between relay polls of Yahoo for watched forex charts.
FOREX_POLL_INTERVAL=10

# Signal engine tuning (apps/signals). All optional — code has sensible defaults.
# EMA-alignment gate every non-breakout signal must pass before it can fire:
#   stack50   (default) EMA9>EMA21>EMA50  — looser, more signals (backtest winner)
#   stack200            EMA9>EMA21>EMA200 — strict major-trend stack, fewest signals
#   filter200           close>EMA200 and EMA9>EMA21
SIGNAL_EMA_GATE=stack50
# Engine mode: "hybrid" (rules pick direction, LLM annotates) or "llm_gate".
# SIGNAL_ENGINE_MODE=hybrid
# Minimum ADX for a trend signal (regime filter); 1h/4h checked vs the next frame up.
# SIGNAL_ADX_MIN=20
# Overextension guard (A): block NEW non-breakout entries once price has stretched
# more than this many ATRs beyond EMA21 — stops chasing a parabolic blow-off. 0
# disables; breakout strategies are exempt. (default 2.5)
# SIGNAL_OVEREXT_ATR_MULT=2.5
# Re-entry cooldown (C): after a same-direction signal on a (symbol, strategy,
# timeframe) closes, suppress a fresh one in that direction for this many BARS —
# stops a runaway trend re-issuing the same BUY every scan. 0 disables; flips are
# never delayed. (default 3)
# SIGNAL_REENTRY_COOLDOWN_BARS=3
# NOTE: env-only changes need `docker compose up -d --force-recreate <svc>`
# (a plain `restart` does NOT reload .env).

# Dodo Payments (Section 3, 16). DODO_PAYMENTS_MODE: "test" (no real charges) or
# "live". API key + product IDs must come from the SAME mode's Dodo dashboard.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_MODE=test
DODO_PRICE_STARTER=
DODO_PRICE_PRO=

# Frontend origin (CORS + billing redirects)
FRONTEND_URL=http://localhost:5173

# Transactional email (Resend). Optional — without RESEND_API_KEY the password
# reset + payment confirmation emails log and no-op. The From address must use a
# domain verified in the Resend dashboard.
RESEND_API_KEY=
RESEND_FROM_EMAIL=PulseCharts <noreply@getpulsecharts.com>
# Where the landing-page "Contact us" form delivers messages (your inbox).
CONTACT_US_EMAIL=

# Auto-trade / broker execution (v2). OFF until accuracy + legal review are done.
AUTO_TRADE_ENABLED=false
# Fernet key for encrypting broker API secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BROKER_ENCRYPTION_KEY=
# Per-trade risk envelope defaults (user config overrides these).
AUTO_TRADE_DEFAULT_RISK_PCT=1.0
AUTO_TRADE_DEFAULT_LEVERAGE=3
AUTO_TRADE_MAX_OPEN_POSITIONS=5
AUTO_TRADE_MAX_DAILY_TRADES=10
AUTO_TRADE_MAX_SLIPPAGE_PCT=0.5
AUTO_TRADE_MAX_SIGNAL_AGE_SEC=600
# How often (seconds) the reconciler polls the broker for open positions.
AUTO_TRADE_RECONCILE_INTERVAL=60
