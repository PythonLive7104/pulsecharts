# PulseCharts backend env (Section 15). Copy to .env and fill in.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Postgres in production (Section 3). Leave unset locally to use the
# SQLite fallback. Example: postgres://user:pass@localhost:5432/pulsecharts
# DATABASE_URL=

# Redis (Channels layer + relay pub/sub)
REDIS_URL=redis://127.0.0.1:6379/0

# Hyperliquid (Section 6). Testnet: wss://api.hyperliquid-testnet.xyz/ws
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Dodo Payments (Section 3, 16). DODO_PAYMENTS_MODE: "test" (no real charges) or
# "live". API key + product IDs must come from the SAME mode's Dodo dashboard.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_MODE=test
DODO_PRICE_STARTER=
DODO_PRICE_PRO=

# Frontend origin (CORS + billing redirects)
FRONTEND_URL=http://localhost:5173
